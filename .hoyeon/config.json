{
  "delivery": {
    "mode": "pr",
    "baseBranch": "main",
    "branchPrefix": "prd",
    "staging": {
      "include": [
        ".gitignore",
        "Package.swift",
        "README.md",
        "Sources",
        "scripts"
      ],
      "exclude": []
    },
    "ci": {
      "watch": true,
      "maxFixAttempts": 2,
      "timeoutSeconds": 240
    }
  },
  "worktree": {
    "enabled": false,
    "link": [],
    "copy": [],
    "setup": []
  },
  "execution": {
    "parallel": false
  },
  "review": {
    "profile": "auto"
  }
}
